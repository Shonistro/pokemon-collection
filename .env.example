# ---------------------------------------------------------------------------
# Frontend environment variables (SAFE to expose — they ship in the browser).
# Copy this file to ".env.local" and fill in values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------

# Your Supabase project URL, e.g. https://abcdefghijklmno.supabase.co
VITE_SUPABASE_URL=

# Your Supabase "anon" / publishable key (the public client key).
# This is intentionally public; Row-Level Security protects the data.
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# DO NOT put the TCG API key here. It must NEVER reach the browser.
# It lives only as a Supabase Edge Function secret:
#   supabase secrets set TCG_API_KEY=tcg_live_xxx
# See README.md -> "Edge Function" for details.
# ---------------------------------------------------------------------------
